{
  "version": 2,
  "projects": [
    {
      "name": "projeto-delivery-frontend",
      "root": "frontend",
      "builds": [
        {
          "src": "package.json",
          "use": "@vercel/static-build",
          "config": {
            "distDir": "dist"
          }
        }
      ],
      "routes": [
        {
          "src": "/(.*)",
          "dest": "/$1"
        }
      ]
    }
  ]
}
